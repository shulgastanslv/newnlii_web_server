[Unit]
Description=Devsy Chat Server - Chat API Server
After=network.target postgresql.service
Wants=network.target

[Service]
Type=simple
WorkingDirectory=/root/Projects/devsy_web_server/chat-api
Environment="PATH=/root/Projects/devsy_web_server/.venv/bin:/usr/local/bin:/usr/bin:/bin"
Environment="PYTHONPATH=/root/Projects/devsy_web_server/chat-api"
ExecStart=/root/Projects/devsy_web_server/.venv/bin/python -m uvicorn app.main:app --host 127.0.0.1 --port 8010 --workers 4
ExecReload=/bin/kill -s HUP $MAINPID
KillMode=mixed
KillSignal=SIGINT
TimeoutStopSec=5
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=devsy-chat-server

# Run as root with full privileges
User=root
Group=root

[Install]
WantedBy=multi-user.target
